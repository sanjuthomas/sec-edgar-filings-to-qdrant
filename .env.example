# Docker network created by sec-edgar-filings compose (default: sec-edgar-filings_default)
SEC_EDGAR_DOCKER_NETWORK=sec-edgar-filings_default

# Qdrant (this project's docker compose)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=filing_chunks

# Local EDGAR filings — .htm file content is read from this directory
EDGAR_DATA_DIR=/Volumes/Transcend/edgar
# Optional: override host bind-mount path in docker-compose (must match EDGAR_DATA_DIR)
# EDGAR_HOST_PATH=/Volumes/Transcend/edgar
ALLOWED_FORMS=10-K,10-Q,10-K/A,10-Q/A

# Kafka — read-only consumer; runs in sec-edgar-filings (service name: kafka)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=filings
KAFKA_GROUP_ID=edgar-etl
KAFKA_AUTO_OFFSET_RESET=earliest

# Embedding model (384 dimensions for bge-small)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSION=384

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Logging
LOG_LEVEL=INFO
